# MDProgress — environment variables
# Copy this file to .env and fill in your values.
# Only NCBI_EMAIL is required. Everything else is optional.

# ── PubMed (required) ─────────────────────────────────────────────────────
# NCBI requires an email for API usage (free, no account needed)
NCBI_EMAIL=you@example.com

# Optional: free API key raises rate limit from 3 → 10 req/s
# Get one at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── OpenAI (optional) ─────────────────────────────────────────────────────
# Needed if you select "openai" embeddings or LLM adjudication in the UI
OPENAI_API_KEY=

# ── Anthropic (optional) ──────────────────────────────────────────────────
# Needed if you select "anthropic" LLM adjudication in the UI
ANTHROPIC_API_KEY=
